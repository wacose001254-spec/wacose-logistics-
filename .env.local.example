# Supabase (from your Supabase project settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser, never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Termii (SMS, and WhatsApp once Meta Business verification is done)
TERMII_API_KEY=
TERMII_SENDER_ID=

# Resend (optional, email notifications/invoice delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Base URL used in generated links (SMS/email), e.g. https://wacose.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron safety net (app/api/cron/stale-bookings)
CRON_SECRET=
ADMIN_ALERT_PHONE=
